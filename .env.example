# Copy to .env and fill in. .env is gitignored and bind-mounted at runtime (never baked
# into the image). All three provider keys are needed for a full tailoring run; corpus
# ingestion alone only needs MISTRAL (embeddings).

MISTRAL_API_KEY=        # REQUIRED — embeddings (corpus ingest + retrieval) + Phase-0 JD analysis
ANTHROPIC_API_KEY=      # REQUIRED — orchestrator + Claude writer + Haiku formatting/validation gate
OPENAI_API_KEY=         # REQUIRED for a run — the GPT-4o-mini writer in the dual-writer loop

# OPTIONAL — passphrase that unlocks full (Sonnet) mode AND corpus write operations (add /
# replace / delete / edit-metadata) — one owner key, both powers (no auth, just a guard against
# accidental expensive runs or public edits — SPEC §3.7 / §12.7 / §12.8). Leave BLANK to keep
# the app demo-only AND read-only: full mode is hidden and corpus writes 403 server-side (fails
# closed; the corpus stays publicly browsable — seed it via the CLI `corpus.ingest`). Set a
# strong value to enable both; in the Web UI it's entered once via the unlock dialog (exchanged
# for a signed HttpOnly cookie — the key is never stored in the browser); the CLI uses --key.
FULL_MODE_KEY=

# OPTIONAL — set to "true" in PRODUCTION (HTTPS) so the full-mode capability cookie is marked
# Secure. Leave blank for local http dev, or the browser won't store the cookie. (D-38)
COOKIE_SECURE=

# OPTIONAL — Job Radar integration (Integration §5.2 / F-50). Base URL of the Job Radar API,
# used server-side to fetch a JD when cv-tailor is opened with `?source=job_radar&job_id=<id>`.
# No auth (Job Radar's `GET /api/jobs/{id}` is public). Override only for local testing — the
# default points at the deployed Job Radar.
JOB_RADAR_API_URL=https://job-radar.michel-portfolio.co.uk

# OPTIONAL — Phase-3 callback (Integration §6 / F-52). Shared secret for cv-tailor → Job Radar:
# when a run that came from Job Radar completes, cv-tailor POSTs summary metrics back to
# `JOB_RADAR_API_URL/api/cv-tailor-results` with `Authorization: Bearer <this>`. Must match
# `CV_TAILOR_SERVICE_KEY` in job-radar/.env. Leave BLANK to disable the callback — the run then
# behaves exactly as in Phase 2 (opt-in by configuration, not a code change). The callback is
# best-effort and never affects run completion.
JOB_RADAR_SERVICE_KEY=

# OPTIONAL — public base URL of THIS cv-tailor deployment, used only for the `output_link` sent
# in the Phase-3 callback above. Defaults to the deployed host; override for local testing.
CV_TAILOR_BASE_URL=https://cv-tailor.michel-portfolio.co.uk

# OPTIONAL — Langfuse v4 tracing (F-53 / D-41). Set all three to emit one trace per run;
# leave BLANK to disable cleanly (every tailor/telemetry.py call no-ops — is_enabled() gates on
# LANGFUSE_PUBLIC_KEY). Keys are PER PROJECT — use this deployment's own cv-tailor project keys,
# not another project's, or traces land in the wrong dashboard. BASE_URL must be the INTERNAL
# Docker address (not the public URL); the backend reaches Langfuse over the shared `tracing`
# network (docker network create tracing). SDK host precedence: LANGFUSE_BASE_URL → LANGFUSE_HOST
# → https://cloud.langfuse.com.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=      # e.g. http://langfuse-langfuse-web-1:3000 (internal Docker addr, not public)

# OPTIONAL — automatic run retention (SPEC §12.9 / D-40). When set to a positive number of days,
# the backend deletes private runs older than that on startup, EXCEPT runs marked keep or
# public_demo. Leave BLANK to disable automatic cleanup (owner can still clean up on demand from
# the Runs tab). Example: RUN_RETENTION_DAYS=7
RUN_RETENTION_DAYS=
