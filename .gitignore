# Secrets
.env

# Real corpus + derived state (irreplaceable / re-embeddable; never commit)
data/cvs/
data/chroma/
outputs/
tmp/
# SQLite run store + WAL sidecars (personal run data, SPEC_SQLITE_MIGRATION §9)
data/cv_tailor.db
data/cv_tailor.db-shm
data/cv_tailor.db-wal
# Job descriptions — real target JDs reveal the job search; keep local only.
# (Commit a sanitised sample as data/jd.example.txt if one is ever needed.)
data/*.txt
!data/*.example.txt

# Candidate Value Creation Model (CVCM, §3.9) — personal career data, never commit
# the real one. The committed *.example.md template shows the structure.
# NB: `candidate/*` (not `candidate/`) — git can't re-include a file whose parent
# DIRECTORY is excluded, so we exclude the contents and negate the template.
candidate/*
!candidate/value_creation_model.example.md

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Node (UI phase)
node_modules/
frontend/dist/

# OS / editor
.DS_Store
Thumbs.db
